{
  "name": "pi-kanban",
  "version": "0.0.0-dev",
  "description": "Workspace for the pi coding agent — sessions, todos, subagents, and more.",
  "main": "server.js",
  "bin": {
    "pi-kanban": "./server.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:demo": "node scripts/build-demo.js",
    "preview:demo": "npm run build:demo && npx --yes http-server dist -p 8765 -c-1",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "release:local": "npm version \"$(git describe --tags --exact-match)\" --no-git-tag-version --allow-same-version && npm publish --access public && git checkout -- package.json package-lock.json",
    "typecheck:extensions": "tsc -p extensions/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^5.8.2",
    "vitepress": "^1.6.4"
  },
  "keywords": [
    "pi-package",
    "kanban",
    "dashboard",
    "observability",
    "sessions",
    "subagents"
  ],
  "files": [
    "server.js",
    "lib/",
    "public/",
    "extensions/",
    "themes/",
    "README.md"
  ],
  "license": "MIT",
  "author": "nikiforovall",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NikiforovAll/pi-kanban.git"
  },
  "bugs": {
    "url": "https://github.com/NikiforovAll/pi-kanban/issues"
  },
  "homepage": "https://github.com/NikiforovAll/pi-kanban#readme",
  "dependencies": {
    "chokidar": "^3.5.3",
    "express": "^4.18.2",
    "open": "^11.0.0",
    "typebox": "^1.1.38"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "video": "https://raw.githubusercontent.com/NikiforovAll/pi-kanban/main/assets/pi-kanban-demo.mp4",
    "image": "https://raw.githubusercontent.com/NikiforovAll/pi-kanban/main/assets/pi-kanban-poster.png"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
